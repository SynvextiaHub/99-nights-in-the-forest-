local function toggleCategoryESP(category, enabled, customCheck)
    local items = ESP_ITEMS[category]
    if enabled then
        for _, item in pairs(ItemsFolder:GetChildren()) do
            if tableFind(items, item.Name) or (customCheck and customCheck(item)) then
                createESPHighlight(item)
                createESPLabel(item)
            end
        end
        for _, item in pairs(Workspace.Characters:GetChildren()) do
            if tableFind(items, item.Name) or (customCheck and customCheck(item)) then
                createESPHighlight(item)
                createESPLabel(item)
            end
        end
        if not espConnections["esp_"..category.."Added"] then
            espConnections["esp_"..category.."Added"] = ItemsFolder.ChildAdded:Connect(function(item)
                if tableFind(items, item.Name) or (customCheck and customCheck(item)) then
                    createESPHighlight(item)
                    createESPLabel(item)
                end
            end)
        end
        if not espConnections["esp_"..category.."CharAdded"] then
            espConnections["esp_"..category.."CharAdded"] = Workspace.Characters.ChildAdded:Connect(function(item)
                if tableFind(items, item.Name) or (customCheck and customCheck(item)) then
                    createESPHighlight(item)
                    createESPLabel(item)
                end
            end)
        end
    else
        for _, item in pairs(ItemsFolder:GetChildren()) do
            if tableFind(items, item.Name) or (customCheck and customCheck(item)) then
                removeESP(item)
            end
        end
        for _, item in pairs(Workspace.Characters:GetChildren()) do
            if tableFind(items, item.Name) or (customCheck and customCheck(item)) then
                removeESP(item)
            end
        end
        if espConnections["esp_"..category.."Added"] then
            espConnections["esp_"..category.."Added"]:Disconnect()
            espConnections["esp_"..category.."Added"] = nil
        end
        if espConnections["esp_"..category.."CharAdded"] then
            espConnections["esp_"..category.."CharAdded"]:Disconnect()
            espConnections["esp_"..category.."CharAdded"] = nil
        end
    end
end

