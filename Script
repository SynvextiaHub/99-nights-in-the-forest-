-- Safe request handling with executor detection
local function safeRequest(data)
    local success, result = pcall(function()
        if syn and syn.request then
            return syn.request(data)
        elseif request and type(request) == "function" then
            return request(data)
        elseif http and http.request then
            return http.request(data)
        else
            local body = game:GetService("HttpService"):GetAsync(data.Url)
            return { Body = body, StatusCode = 200, Success = true }
        end
    end)
    if success then return result end
    return { Body = "{}", StatusCode = 0, Success = false }
end

local function retryRequest(data, retries)
    retries = retries or 2
    for i = 1, retries do
        local result = safeRequest(data)
        if result and result.StatusCode == 200 then return result end
        task.wait(1)
    end
    return { Success = false }
end

-- Helper: table.find replacement
local function tableFind(t, value)
    for i, v in ipairs(t) do
        if v == value then return i end
    end
    return nil
end

