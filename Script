local MAX_ITEM_DISTANCE = 200
local function findNearestFoodItem()
    local char = LP.Character
    if not (char and char:FindFirstChild("HumanoidRootPart")) then return nil end
    local rootPart = char.HumanoidRootPart
    local closestItem, closestDistance = nil, math.huge
    for _, item in ipairs(ItemsFolder:GetChildren()) do
        if globalEnv.autoConsumeList[item.Name] then
            local pos = if item:IsA("Model") then item:GetPivot().Position else (item:FindFirstChildWhichIsA("BasePart") and item:FindFirstChildWhichIsA("BasePart").Position) or Vector3.new()
            local distance = (rootPart.Position - pos).Magnitude
            if distance < closestDistance and distance <= MAX_ITEM_DISTANCE then
                closestItem = item
                closestDistance = distance
            end
        end
    end
    return closestItem
end

local function consumeInventoryFood()
    local inventory = LP:FindFirstChild("Inventory")
    if not inventory then return end
    for foodName, enabled in pairs(globalEnv.autoConsumeList) do
        if enabled then
            local item = inventory:FindFirstChild(foodName)
            if item and (item:GetAttribute("RestoreHunger") or item:GetAttribute("RestoreHealth")) then
                consume(item)
            end
        end
    end
end

task.spawn(function()
    while true do
        if AUTO_CONSUME_ENABLED then
            consumeInventoryFood()
            local item = findNearestFoodItem()
            if item and (item:GetAttribute("RestoreHunger") or item:GetAttribute("RestoreHealth")) then
                consume(item)
            end
        end
        task.wait(0.3)
    end
end)

