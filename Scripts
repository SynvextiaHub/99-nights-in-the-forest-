            for _, item in pairs(itemsContainer:GetChildren()) do
                if (table.find(items, item.Name) or (customCheck and customCheck(item))) then
                    createESPHighlight(item)
                    createESPLabel(item)
                end
            end
        end
        if charsContainer then
            for _, item in pairs(charsContainer:GetChildren()) do
                if (table.find(items, item.Name) or (customCheck and customCheck(item))) then
                    createESPHighlight(item)
                    createESPLabel(item)
                end
            end
        end
        if not espConnections["esp_"..category.."Added"] and itemsContainer then
            espConnections["esp_"..category.."Added"] = itemsContainer.ChildAdded:Connect(function(item)
                if (table.find(items, item.Name) or (customCheck and customCheck(item))) then
                    createESPHighlight(item)
                    createESPLabel(item)
                end
            end)
        end
        if not espConnections["esp_"..category.."CharAdded"] and charsContainer then
            espConnections["esp_"..category.."CharAdded"] = charsContainer.ChildAdded:Connect(function(item)
                if (table.find(items, item.Name) or (customCheck and customCheck(item))) then
                    createESPHighlight(item)
                    createESPLabel(item)
                end
            end)
        end
    else
        if itemsContainer then
            for _, item in pairs(itemsContainer:GetChildren()) do
                if (table.find(items, item.Name) or (customCheck and customCheck(item))) then
                    removeESP(item)
                end
            end
        end
        if charsContainer then
            for _, item in pairs(charsContainer:GetChildren()) do
                if (table.find(items, item.Name) or (customCheck and customCheck(item))) then
                    removeESP(item)
                end
            end
        end
        if espConnections["esp_"..category.."Added"] then
            espConnections["esp_"..category.."Added"]:Disconnect()
            espConnections["esp_"..category.."Added"] = nil
        end
        if espConnections["esp_"..category.."CharAdded"] then
            espConnections["esp_"..category.."CharAdded"]:Disconnect()
            espConnections["esp_"..category.."CharAdded"] = nil
        end
    end
end

